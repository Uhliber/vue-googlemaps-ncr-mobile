# ── Google Maps ─────────────────────────────────────────────────────────────
# Get a key at: https://console.cloud.google.com/
# Enable: Maps JavaScript API
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ── OpenCelliD ───────────────────────────────────────────────────────────────
# Get a token at: https://opencellid.org (free account)
# Used to fetch real cell tower data for Globe, Smart, and DITO within NCR.
# If left as the placeholder, the app falls back to research-based mock data.
VITE_OPENCELLID_TOKEN=YOUR_OPENCELLID_TOKEN

# ── Optional: production OpenCelliD proxy ────────────────────────────────────
# In development the Vite dev server proxies /api/opencellid → opencellid.org.
# In production, deploy a lightweight reverse proxy (e.g. a Cloudflare Worker
# or Vercel serverless function) and set its URL here.
# Leave unset to call opencellid.org directly (may require CORS to be enabled).
# VITE_OPENCELLID_BASE_URL=https://your-proxy.example.com
